# Discord webhook for notifications
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
# Optional: user/role mention on failure (e.g. <@123456789012345678>)
DISCORD_MENTION=

# OCI instance configuration
# Compartment: OCI Console -> Identity -> Compartments -> OCID
OCI_COMPARTMENT_ID=ocid1.compartment.oc1..aaaa...

# Availability Domain: OCI Console -> Compute -> Instances -> Create -> Availability Domain
# Format: <tenancy-name>:REGION-AD-N  e.g. abcd:AP-SINGAPORE-1-AD-1
OCI_AVAILABILITY_DOMAIN=abcd:AP-SINGAPORE-1-AD-1

# Subnet: OCI Console -> Networking -> Virtual Cloud Networks -> your VCN -> Subnets
OCI_SUBNET_ID=ocid1.subnet.oc1.ap-singapore-1.aaaa...

# Image: OCI Console -> Compute -> Images -> Platform Images -> Ubuntu 22.04 Minimal aarch64
OCI_IMAGE_ID=ocid1.image.oc1.ap-singapore-1.aaaa...

# Your SSH public key (full string, e.g. contents of ~/.ssh/id_ed25519.pub)
OCI_SSH_PUBLIC_KEY=ssh-ed25519 AAAA... yourname

# Shape config (defaults shown — free tier max is 4 OCPU / 24 GB)
OCI_SHAPE=VM.Standard.A1.Flex
OCI_OCPU_COUNT=4
OCI_MEMORY_GB=24

# How often to retry (seconds). Don't go below 30 or OCI will rate-limit you.
RETRY_INTERVAL_SEC=60
